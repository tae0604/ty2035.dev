---
import BaseLayout from './BaseLayout.astro';
import { getEntry } from 'astro:content';
import '../styles/blog.css';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  readTime?: string;
  projectLink?: string;
}

const { title, description, date, tags = [], readTime, projectLink } = Astro.props;

const cleanProjectLink = projectLink ? projectLink.split('#')[0].replace(/['"]/g, '').trim().toLowerCase() : '';
const relatedProject = cleanProjectLink ? await getEntry('projects', cleanProjectLink) : null;

const fmtDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
}).format(date);

// Parse title: "Hello *world*" → segments with italic flag
// Write *word* in the frontmatter title to make that portion italic-serif.
const titleParts = title.split(/(\*[^*]+\*)/g).map((chunk) => {
  if (chunk.startsWith('*') && chunk.endsWith('*')) {
    return { italic: true, text: chunk.slice(1, -1) };
  }
  return { italic: false, text: chunk };
});

// Strip markers for the plain-text title used in <title> and OG meta
const plainTitle = title.replace(/\*([^*]+)\*/g, '$1');
---

<BaseLayout title={`${plainTitle} — ty2035.dev`} description={description}>
  <main class="post-container">
    <article class="post">
      <header class="post-header">
        <div class="post-meta">
          <time datetime={date.toISOString()}>{fmtDate}</time>
          {readTime && (
            <>
              <span class="post-sep">·</span>
              <span>{readTime}</span>
            </>
          )}
          {tags.length > 0 && tags.map((tag) => (
            <>
              <span class="post-sep">·</span>
              <span class="post-tag">#{tag}</span>
            </>
          ))}
        </div>
        <h1 class="post-title">
          {titleParts.map((part) =>
            part.italic ? <span class="italic-serif">{part.text}</span> : part.text
          )}
        </h1>
        <p class="post-lede">{description}</p>
      </header>

      <div class="post-body">
        <slot />
      </div>

      {relatedProject && (
        <div class="post-project-link">
          <div class="post-project-link-label">Related Project</div>
          <a href={`/projects/${relatedProject.slug}/`} class="post-project-card">
            <div class="post-project-card-info">
              <span class="post-project-card-title">{relatedProject.data.title.replace(/\*([^*]+)\*/g, '$1')}</span>
              <p class="post-project-card-desc">{relatedProject.data.description}</p>
            </div>
            <span class="post-project-card-arrow">View Project →</span>
          </a>
        </div>
      )}
    </article>

    <nav class="post-nav">
      <a href="/blog/" class="post-nav-link">← All posts</a>
      <a href="/" class="post-nav-link post-nav-link--right">Home ↗</a>
    </nav>
  </main>
</BaseLayout>