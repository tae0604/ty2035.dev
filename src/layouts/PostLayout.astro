---
import BaseLayout from './BaseLayout.astro';
import { getEntry } from 'astro:content';
import '../styles/blog.css';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  readTime?: string;
  projectLink?: string;
}

const { title, description, date, tags = [], readTime, projectLink } = Astro.props;

const cleanProjectLink = projectLink ? projectLink.split('#')[0].replace(/['"]/g, '').trim().toLowerCase() : '';
const relatedProject = cleanProjectLink ? await getEntry('projects', cleanProjectLink) : null;

const fmtDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
}).format(date);

// Parse title: "Hello *world*" → segments with italic flag
// Write *word* in the frontmatter title to make that portion italic-serif.
const titleParts = title.split(/(\*[^*]+\*)/g).map((chunk) => {
  if (chunk.startsWith('*') && chunk.endsWith('*')) {
    return { italic: true, text: chunk.slice(1, -1) };
  }
  return { italic: false, text: chunk };
});

// Strip markers for the plain-text title used in <title> and OG meta
const plainTitle = title.replace(/\*([^*]+)\*/g, '$1');
---

<BaseLayout title={`${plainTitle} — ty2035.dev`} description={description}>
  <main class="post-container">
    <article class="post">
      <header class="post-header">
        <div class="post-meta">
          <time datetime={date.toISOString()}>{fmtDate}</time>
          {readTime && (
            <>
              <span class="post-sep">·</span>
              <span>{readTime}</span>
            </>
          )}
          {tags.length > 0 && tags.map((tag) => (
            <>
              <span class="post-sep">·</span>
              <span class="post-tag">#{tag}</span>
            </>
          ))}
        </div>
        <h1 class="post-title">
          {titleParts.map((part) =>
            part.italic ? <span class="italic-serif">{part.text}</span> : part.text
          )}
        </h1>
        <p class="post-lede">{description}</p>
      </header>

      <div class="post-body">
        <slot />
      </div>

      {relatedProject && (
        <div class="post-project-link">
          <div class="post-project-link-label">Related Project</div>
          <a href={`/projects/${relatedProject.slug}/`} class="post-project-card">
            <div class={`work-thumb post-project-thumb ${relatedProject.data.thumbImage ? '' : `work-thumb--${relatedProject.data.thumbColor}`}`} aria-hidden="true">
              {relatedProject.data.thumbImage ? (
                <img src={relatedProject.data.thumbImage} alt="" />
              ) : (
                <svg viewBox="0 0 64 36" preserveAspectRatio="xMidYMid meet">
                  {relatedProject.data.thumbIcon === 'circle' && (
                    <>
                      <circle cx="32" cy="18" r="9" fill="white" opacity="0.95" />
                      <circle cx="32" cy="18" r="3.5" fill="currentColor" opacity="0.7" />
                    </>
                  )}
                  {relatedProject.data.thumbIcon === 'square' && (
                    <>
                      <rect x="23" y="9" width="18" height="18" rx="4" fill="white" opacity="0.95" />
                      <rect x="27" y="13" width="10" height="10" rx="2" fill="currentColor" opacity="0.7" />
                    </>
                  )}
                  {relatedProject.data.thumbIcon === 'triangle' && (
                    <>
                      <polygon points="32,7 43,27 21,27" fill="white" opacity="0.95" />
                      <circle cx="32" cy="21" r="2.5" fill="currentColor" opacity="0.7" />
                    </>
                  )}
                  {relatedProject.data.thumbIcon === 'wave' && (
                    <>
                      <path d="M20 22 Q32 8 44 22" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" opacity="0.95" />
                      <circle cx="32" cy="22" r="3" fill="white" opacity="0.9" />
                    </>
                  )}
                  {relatedProject.data.thumbIcon === 'dots' && (
                    <>
                      <circle cx="32" cy="18" r="8" fill="none" stroke="white" stroke-width="2" stroke-dasharray="3 3" opacity="0.8" />
                      <circle cx="32" cy="18" r="2" fill="white" opacity="0.8" />
                    </>
                  )}
                  {relatedProject.data.thumbIcon === 'ring' && (
                    <>
                      <circle cx="32" cy="18" r="9" fill="none" stroke="white" stroke-width="2.5" opacity="0.95" />
                      <circle cx="32" cy="18" r="2" fill="white" opacity="0.9" />
                    </>
                  )}
                </svg>
              )}
            </div>
            <div class="post-project-card-info">
              <span class="post-project-card-title">{relatedProject.data.title.replace(/\*([^*]+)\*/g, '$1')}</span>
              <p class="post-project-card-desc">{relatedProject.data.description}</p>
            </div>
            <span class="post-project-card-arrow">View Project →</span>
          </a>
        </div>
      )}
    </article>

    <nav class="post-nav">
      <a href="/blog/" class="post-nav-link">← All posts</a>
      <a href="/" class="post-nav-link post-nav-link--right">Home ↗</a>
    </nav>
  </main>
</BaseLayout>