---
import IdentityCard from './IdentityCard.astro';
---

<section class="hero">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-main">
        <div class="hero-eyebrow reveal" data-delay="0">
          <span class="status-pill">
            <span class="dot" aria-hidden="true"></span>
            <span>Available for new work</span>
          </span>
          <span class="status-pill status-pill--quiet">
            <svg viewBox="0 0 14 14" width="11" height="11" aria-hidden="true" style="opacity:0.7">
              <path
                d="M7 2 L1 5 L7 8 L13 5 Z M3 6.5 V9.5 C3 10 5 11 7 11 C9 11 11 10 11 9.5 V6.5"
                fill="none" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"
              />
            </svg>
            <span>Middle school · Seoul</span>
          </span>
        </div>

        <h1 class="hero-name reveal" data-delay="1">
          Tae Young <span class="italic-serif">Ryu</span><span class="period">.</span>
        </h1>

        <p class="hero-tagline reveal" data-delay="2">
          A <strong>middle schooler</strong> from Seoul who designs interfaces in Figma
          and ships them in code. I'm most at home in the space between <em>pixels</em>
          and <em>systems</em>.
        </p>

        <div class="hero-meta reveal" data-delay="3">
          <div class="meta-row">
            <span class="meta-key">Location</span>
            <span class="meta-val">Seoul, Korea <span class="mono">(GMT+9)</span></span>
          </div>
          <div class="meta-row">
            <span class="meta-key">Stage</span>
            <span class="meta-val"><span class="accent">Middle school student</span> · learning out loud since 2018</span>
          </div>
          <div class="meta-row">
            <span class="meta-key">Now</span>
            <span class="meta-val">Building <span class="accent2">ty2035.dev</span> · Learning motion on the web</span>
          </div>
          <div class="meta-row">
            <span class="meta-key">Stack</span>
            <span class="meta-val"><span class="mono">Entry · Figma · HTML/CSS · JavaScript</span></span>
          </div>
          <div class="meta-row">
            <span class="meta-key">Contact</span>
            <span class="meta-val"><a href="mailto:mail@ty2035.dev" class="mono">mail@ty2035.dev</a></span>
          </div>
        </div>

        <div class="hero-cta reveal" data-delay="4">
          <a class="btn btn--primary" href="#works">
            <span>See selected work</span>
            <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
              <path
                d="M5 12h14M13 6l6 6-6 6"
                fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round"
              />
            </svg>
          </a>
          <a class="btn btn--ghost" href="#connect">Say hello</a>
        </div>
      </div>

      <IdentityCard />
    </div>
  </div>

  <div class="scroll-hint" aria-hidden="true">
    <span>scroll to read</span>
    <svg class="arrow" viewBox="0 0 14 14" width="14" height="14">
      <path d="M7 2v10M3 8l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
    </svg>
  </div>
</section>