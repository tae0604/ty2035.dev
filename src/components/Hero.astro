---
// Single-column editorial hero — more like a real indie site.
// No "identity card" split — this was the most AI-templatey thing.
---

<section class="hero">
  <div class="container">
    <div class="hero-stack">
      <!-- Top status line — small, monospace, like a terminal prompt -->
      <div class="hero-status reveal" data-delay="0">
        <span class="status-dot" aria-hidden="true"></span>
        <span class="status-text">Available for freelance &amp; collabs</span>
        <span class="status-sep">·</span>
        <span class="status-time"><span id="clock">—:—:—</span> KST</span>
      </div>

      <!-- Name — big, simple, no gradients -->
      <h1 class="hero-name reveal" data-delay="1">
        Tae Young <span class="italic-serif">Ryu</span><span class="period">.</span>
      </h1>

      <!-- Tagline — one short paragraph, conversational -->
      <p class="hero-tagline reveal" data-delay="2">
        14-year-old designer &amp; developer from Seoul.
        I make small internet things in the cracks between school and sleep.
      </p>

      <!-- Metadata table — footnote-style, very Paco Coursey -->
      <dl class="hero-facts reveal" data-delay="3">
        <div class="fact">
          <dt>Where</dt>
          <dd>Seoul, Korea <span class="mono muted">(GMT+9)</span></dd>
        </div>
        <div class="fact">
          <dt>Who</dt>
          <dd>Middle schooler, @ty2035 everywhere</dd>
        </div>
        <div class="fact">
          <dt>Now</dt>
          <dd>Making this site. Learning Figma. Reading about typography.</dd>
        </div>
        <div class="fact">
          <dt>Tools</dt>
          <dd><span class="mono">Entry, Figma, HTML, CSS, JavaScript</span></dd>
        </div>
        <div class="fact">
          <dt>Mail</dt>
          <dd><a class="mono" href="mailto:mail@ty2035.dev">mail@ty2035.dev</a></dd>
        </div>
      </dl>
    </div>

    <!-- Brand mark — tiny, bottom right, like a watermark -->
    <div class="hero-mark reveal" data-delay="4" aria-hidden="true">
      <img src="/ty2035.svg" alt="" width="32" height="32" />
    </div>
  </div>
</section>