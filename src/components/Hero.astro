---
// Single-column editorial hero.
// No status pill, no watermark — just the essentials.
---

<section class="hero">
  <div class="container">
    <div class="hero-stack">
      <!-- Name — big, simple -->
      <h1 class="hero-name reveal" data-delay="0">
        Tae Young <span class="italic-serif">Ryu</span><span class="period">.</span>
      </h1>

      <!-- Tagline -->
      <p class="hero-tagline reveal" data-delay="1">
        14-year-old designer &amp; developer from Seoul.
        I make small internet things in the cracks between school and sleep.
      </p>

      <!-- Metadata -->
      <dl class="hero-facts reveal" data-delay="2">
        <div class="fact">
          <dt>Where</dt>
          <dd>Seoul, Korea <span class="mono muted">(GMT+9)</span></dd>
        </div>
        <div class="fact">
          <dt>Who</dt>
          <dd>Middle schooler, @ty2035 everywhere</dd>
        </div>
        <div class="fact">
          <dt>Now</dt>
          <dd>Making this site. Learning Figma. Reading about typography.</dd>
        </div>
        <div class="fact">
          <dt>Tools</dt>
          <dd><span class="mono">Entry, Figma, HTML, CSS, JavaScript</span></dd>
        </div>
        <div class="fact">
          <dt>Mail</dt>
          <dd><a class="mono" href="mailto:mail@ty2035.dev">mail@ty2035.dev</a></dd>
        </div>
      </dl>
    </div>
  </div>
</section>