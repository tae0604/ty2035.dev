---
import { getCollection } from 'astro:content';
import ProjectRow from './ProjectRow.astro';

const allProjects = (await getCollection('projects'))
  .filter((p) => p.data.featured !== false)
  .sort((a, b) => a.data.order - b.data.order);

const MAX_ON_HOME = 5;
const projects = allProjects.slice(0, MAX_ON_HOME);
const showAll = allProjects.length > MAX_ON_HOME;
---

<section id="works" class="section">
  <div class="container">
    <div class="section-head">
      <div class="section-head-left">
        <div class="section-label">Work</div>
        <h2 class="section-title">Things I've <span class="italic-serif">made</span>.</h2>
      </div>
    </div>

    <div class="works-index">
      {projects.map((project) => <ProjectRow project={project} />)}
    </div>

    {showAll && (
      <a class="blog-all" href="/projects/">
        <span>View all projects</span>
        <span class="blog-all-arrow">→</span>
      </a>
    )}
  </div>
</section>