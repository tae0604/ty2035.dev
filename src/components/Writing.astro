---
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .filter((p) => p.data.draft !== true)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Still cap the homepage display at 5 newest
const posts = allPosts.slice(0, 5);

const fmtDate = (d: Date) =>
  new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).format(d);

// Helper: render titles with *italic* markers → italic-serif span
// e.g. "Hello *world*" → Hello <em>world</em>
const renderTitle = (title: string) => {
  return title.split(/(\*[^*]+\*)/g).map((chunk) => {
    if (chunk.startsWith('*') && chunk.endsWith('*')) {
      return { italic: true, text: chunk.slice(1, -1) };
    }
    return { italic: false, text: chunk };
  });
};
---

<section id="writing" class="section">
  <div class="container">
    <div class="section-head">
      <div class="section-head-left">
        <div class="section-label">Blog</div>
        <h2 class="section-title">What I'm <span class="italic-serif">thinking</span>.</h2>
      </div>
    </div>

    {posts.length === 0 ? (
      <div class="blog-empty">Nothing here yet. Working on it.</div>
    ) : (
      <>
        <ul class="blog-list">
          {posts.map((post) => (
            <li class="blog-item">
              <a href={`/blog/${post.slug}/`} class="blog-link">
                <span class="blog-date">{fmtDate(post.data.date)}</span>
                <span class="blog-title">
                  {renderTitle(post.data.title).map((part) =>
                    part.italic ? <span class="italic-serif">{part.text}</span> : part.text
                  )}
                </span>
                <span class="blog-arrow">→</span>
              </a>
            </li>
          ))}
        </ul>
        <a class="blog-all" href="/blog/">
          <span>View all posts</span>
          <span class="blog-all-arrow">→</span>
        </a>
      </>
    )}
  </div>
</section>