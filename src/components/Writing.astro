---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => p.data.draft !== true)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmtDate = (d: Date) =>
  new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).format(d);
---

<section id="writing" class="section">
  <div class="container">
    <div class="section-head">
      <div class="section-head-left">
        <div class="section-label">Writing</div>
        <h2 class="section-title">Notes, mostly.</h2>
      </div>
    </div>

    {posts.length === 0 ? (
      <div class="blog-empty">Nothing here yet. Working on it.</div>
    ) : (
      <ul class="blog-list">
        {posts.map((post) => (
          <li class="blog-item">
            <a href={`/blog/${post.slug}/`} class="blog-link">
              <span class="blog-date">{fmtDate(post.data.date)}</span>
              <span class="blog-title">{post.data.title}</span>
              <span class="blog-arrow">→</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</section>