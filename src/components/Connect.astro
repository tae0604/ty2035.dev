---
---

<section id="connect" class="section">
  <div class="container">
    <div class="section-head">
      <div class="section-head-left">
        <div class="section-label">Contact</div>
        <h2 class="section-title">
          Say hi — I'm friendly.
        </h2>
      </div>
    </div>

    <div class="contact">
      <p class="contact-lede">
        Best way to reach me is email. I also hang out in a few other places.
      </p>

      <ul class="contact-list">
        <li>
          <span class="contact-key">Email</span>
          <a href="mailto:mail@ty2035.dev" class="contact-val">mail@ty2035.dev</a>
        </li>
        <li>
          <span class="contact-key">Entry</span>
          <a href="https://playentry.org/profile/ty2035" target="_blank" rel="noopener" class="contact-val">
            playentry.org/profile/ty2035
          </a>
        </li>
        <li>
          <span class="contact-key">Figma</span>
          <a href="https://www.figma.com/@ty2035" target="_blank" rel="noopener" class="contact-val">
            figma.com/@ty2035
          </a>
        </li>
        <li>
          <span class="contact-key">GitHub</span>
          <a href="https://github.com/ty2035" target="_blank" rel="noopener" class="contact-val">
            github.com/ty2035
          </a>
        </li>
        <li>
          <span class="contact-key">Discord</span>
          <button class="contact-val contact-copy" data-copy="ty2035" type="button">
            @ty2035 <span class="contact-copy-hint">click to copy</span>
          </button>
        </li>
      </ul>
    </div>

    <div class="toast" id="toast" role="status" aria-live="polite">
      <span class="toast-inner">Copied to clipboard</span>
    </div>
  </div>
</section>