---
---

<section id="connect" class="section">
  <div class="container">
    <div class="section-head">
      <div class="section-head-left">
        <div class="section-label">Contact</div>
        <h2 class="section-title">
          Get <span class="italic-serif">in touch</span>.
        </h2>
      </div>
    </div>

    <p class="contact-lede">
      Best way to reach me is email. I also hang out in a few other places.
    </p>

    <div class="links-grid">
      <a class="link-card" href="mailto:mail@ty2035.dev">
        <div class="link-icon">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 6h18v12H3zM3 6l9 7 9-7"/>
          </svg>
        </div>
        <div class="link-body">
          <div class="link-label">Email</div>
          <div class="link-handle">mail@ty2035.dev</div>
        </div>
        <div class="link-arrow">↗</div>
      </a>

      <a class="link-card" href="https://playentry.org/profile/ty2035" target="_blank" rel="noopener">
        <div class="link-icon">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <circle cx="12" cy="12" r="8"/>
          </svg>
        </div>
        <div class="link-body">
          <div class="link-label">Entry</div>
          <div class="link-handle">playentry.org/profile/ty2035</div>
        </div>
        <div class="link-arrow">↗</div>
      </a>

      <a class="link-card" href="https://www.figma.com/@ty2035" target="_blank" rel="noopener">
        <div class="link-icon">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M8 2h4v8H8a4 4 0 0 1 0-8zm4 0h4a4 4 0 0 1 0 8h-4V2zm4 8a4 4 0 1 1 0 8 4 4 0 0 1 0-8zm-8 0h4v8a4 4 0 1 1-4-4v-4zm0 12a4 4 0 0 1-4-4h4v4z"/>
          </svg>
        </div>
        <div class="link-body">
          <div class="link-label">Figma</div>
          <div class="link-handle">figma.com/@ty2035</div>
        </div>
        <div class="link-arrow">↗</div>
      </a>

      <a class="link-card" href="https://github.com/ty2035" target="_blank" rel="noopener">
        <div class="link-icon">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.6.5.5 5.6.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2.2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.4-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2 1-.3 2-.4 3-.4s2 .1 3 .4c2.3-1.5 3.3-1.2 3.3-1.2.7 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.6 18.4.5 12 .5z"/>
          </svg>
        </div>
        <div class="link-body">
          <div class="link-label">GitHub</div>
          <div class="link-handle">github.com/ty2035</div>
        </div>
        <div class="link-arrow">↗</div>
      </a>

      <button class="link-card" data-copy="ty2035" type="button">
        <div class="link-icon">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M20 4.4A19 19 0 0 0 15.5 3l-.2.4a14 14 0 0 0-6.6 0L8.5 3A19 19 0 0 0 4 4.4C1.3 8.4.6 12.4.9 16.4a19 19 0 0 0 5.7 2.9l.6-1a12 12 0 0 1-2-1l.5-.4a13 13 0 0 0 12.6 0l.5.4a12 12 0 0 1-2 1l.6 1a19 19 0 0 0 5.7-2.9c.4-4.8-.7-8.8-3.1-12zM9.3 14.3c-1 0-1.8-1-1.8-2.2s.8-2.2 1.8-2.2 1.8 1 1.8 2.2-.8 2.2-1.8 2.2zm5.4 0c-1 0-1.8-1-1.8-2.2s.8-2.2 1.8-2.2 1.8 1 1.8 2.2-.8 2.2-1.8 2.2z"/>
          </svg>
        </div>
        <div class="link-body">
          <div class="link-label">Discord</div>
          <div class="link-handle">@ty2035 <span class="link-copy-hint">click to copy</span></div>
        </div>
        <div class="link-arrow">⧉</div>
      </button>
    </div>

    <div class="toast" id="toast" role="status" aria-live="polite">
      <span class="toast-inner">Copied to clipboard</span>
    </div>
  </div>
</section>