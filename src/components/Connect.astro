---

<section id="connect" class="section">
  <div class="container">
    <div class="section-head">
      <div class="section-head-left">
        <div class="section-label">Contact</div>
        <h2 class="section-title">
          Get <span class="italic-serif">in touch</span>.
        </h2>
      </div>
    </div>

    <p class="contact-lede">
      Best way to reach me is email. I also hang out in a few other places.
    </p>

    <div class="links-grid">
      <a class="link-card" href="mailto:mail@ty2035.dev">
        <div class="link-icon">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2"></rect>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
          </svg>
        </div>
        <div class="link-body">
          <div class="link-label">Email</div>
          <div class="link-handle">mail@ty2035.dev</div>
        </div>
        <div class="link-arrow">↗</div>
      </a>

      <a class="link-card" href="https://playentry.org/profile/604b0900b950ec00ef858ff5" target="_blank" rel="noopener">
        <div class="link-icon">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="6" width="20" height="12" rx="3"></rect>
            <path d="M6 12h4m-2-2v4m7-2h.01m2.99-2h.01"></path>
          </svg>
        </div>
        <div class="link-body">
          <div class="link-label">Entry</div>
          <div class="link-handle">playentry.org/profile/604b0900b950ec00ef858ff5</div>
        </div>
        <div class="link-arrow">↗</div>
      </a>

      <a class="link-card" href="https://www.figma.com/@ty2013" target="_blank" rel="noopener">
        <div class="link-icon">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 5.5A3.5 3.5 0 0 1 8.5 2H12v7H8.5A3.5 3.5 0 0 1 5 5.5z"></path>
            <path d="M12 2h3.5a3.5 3.5 0 1 1 0 7H12V2z"></path>
            <path d="M12 9h3.5a3.5 3.5 0 1 1-3.5 3.5V9z"></path>
            <path d="M5 12.5A3.5 3.5 0 0 1 8.5 9H12v3.5A3.5 3.5 0 1 1 5 12.5z"></path>
            <path d="M5 19.5A3.5 3.5 0 0 1 8.5 16H12v3.5A3.5 3.5 0 1 1 5 19.5z"></path>
          </svg>
        </div>
        <div class="link-body">
          <div class="link-label">Figma</div>
          <div class="link-handle">figma.com/@ty2013</div>
        </div>
        <div class="link-arrow">↗</div>
      </a>

      <a class="link-card" href="https://github.com/tae0604" target="_blank" rel="noopener">
        <div class="link-icon">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
            <path d="M9 18c-4.51 2-5-2-7-2"></path>
          </svg>
        </div>
        <div class="link-body">
          <div class="link-label">GitHub</div>
          <div class="link-handle">github.com/tae0604</div>
        </div>
        <div class="link-arrow">↗</div>
      </a>

      <button class="link-card" data-copy="ty2035" type="button">
        <div class="link-icon">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M18.63 7A17.74 17.74 0 0 0 15 5.14l-.27.59a16.14 16.14 0 0 0-5.46 0l-.27-.59A17.74 17.74 0 0 0 5.37 7 19 19 0 0 0 3 17.06a18.66 18.66 0 0 0 5.13 2.62l1-.67a12 12 0 0 1-1.63-1.07l.4-.38a14.85 14.85 0 0 0 8.2 0l.4.38a12 12 0 0 1-1.63 1.07l1 .67A18.66 18.66 0 0 0 21 17.06 19 19 0 0 0 18.63 7z"></path>
            <circle cx="9.5" cy="12.5" r="1.5" fill="currentColor"></circle>
            <circle cx="14.5" cy="12.5" r="1.5" fill="currentColor"></circle>
          </svg>
        </div>
        <div class="link-body">
          <div class="link-label">Discord</div>
          <div class="link-handle">@ty2035 <span class="link-copy-hint">click to copy</span></div>
        </div>
        <div class="link-arrow">⧉</div>
      </button>
    </div>

    <div class="toast" id="toast" role="status" aria-live="polite">
      <span class="toast-inner">Copied to clipboard</span>
    </div>
  </div>
</section>