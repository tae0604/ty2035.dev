---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, description, year, url, tags, thumbImage, thumbColor, thumbIcon } = project.data;

const href = url ?? '#';
const external = url ? true : false;
---

<a
  class="work-row"
  href={href}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener' : undefined}
>
  <div class={`work-thumb ${thumbImage ? '' : `work-thumb--${thumbColor}`}`} aria-hidden="true">
    {thumbImage ? (
      <img src={thumbImage} alt="" />
    ) : (
      <svg viewBox="0 0 64 36" preserveAspectRatio="xMidYMid meet">
        {thumbIcon === 'circle' && (
          <>
            <circle cx="32" cy="18" r="9" fill="white" opacity="0.95" />
            <circle cx="32" cy="18" r="3.5" fill="currentColor" opacity="0.7" />
          </>
        )}
        {thumbIcon === 'square' && (
          <>
            <rect x="23" y="9" width="18" height="18" rx="4" fill="white" opacity="0.95" />
            <rect x="27" y="13" width="10" height="10" rx="2" fill="currentColor" opacity="0.7" />
          </>
        )}
        {thumbIcon === 'triangle' && (
          <>
            <polygon points="32,7 43,27 21,27" fill="white" opacity="0.95" />
            <circle cx="32" cy="21" r="2.5" fill="currentColor" opacity="0.7" />
          </>
        )}
        {thumbIcon === 'wave' && (
          <>
            <path d="M20 22 Q32 8 44 22" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" opacity="0.95" />
            <circle cx="32" cy="22" r="3" fill="white" opacity="0.9" />
          </>
        )}
        {thumbIcon === 'dots' && (
          <>
            <circle cx="32" cy="18" r="8" fill="none" stroke="white" stroke-width="2" stroke-dasharray="3 3" opacity="0.8" />
            <circle cx="32" cy="18" r="2" fill="white" opacity="0.8" />
          </>
        )}
        {thumbIcon === 'ring' && (
          <>
            <circle cx="32" cy="18" r="9" fill="none" stroke="white" stroke-width="2.5" opacity="0.95" />
            <circle cx="32" cy="18" r="2" fill="white" opacity="0.9" />
          </>
        )}
      </svg>
    )}
  </div>

  <div class="work-year">{year}</div>

  <div>
    <div class="work-title">{title}</div>
    <div class="work-desc">{description}</div>
  </div>

  <div class="work-tags">
    {tags.map((tag) => <span class="work-tag">{tag}</span>)}
  </div>

  <div class="work-arrow">↗</div>
</a>