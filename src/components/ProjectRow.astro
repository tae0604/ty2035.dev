---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, description, year, url, tags, thumbImage, thumbColor, thumbIcon } = project.data;

const href = url ?? '#';
const external = url ? true : false;
---

<a
  class="work-row"
  href={href}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener' : undefined}
>
  <div class={`work-thumb ${thumbImage ? '' : `work-thumb--${thumbColor}`}`} aria-hidden="true">
    {thumbImage ? (
      <img src={thumbImage} alt="" />
    ) : (
      <svg viewBox="0 0 32 32">
        {thumbIcon === 'circle' && (
          <>
            <circle cx="16" cy="16" r="9" fill="white" opacity="0.95" />
            <circle cx="16" cy="16" r="3.5" fill="currentColor" opacity="0.7" />
          </>
        )}
        {thumbIcon === 'square' && (
          <>
            <rect x="8" y="8" width="16" height="16" rx="4" fill="white" opacity="0.95" />
            <rect x="12" y="12" width="8" height="8" rx="2" fill="currentColor" opacity="0.7" />
          </>
        )}
        {thumbIcon === 'triangle' && (
          <>
            <polygon points="16,6 26,24 6,24" fill="white" opacity="0.95" />
            <circle cx="16" cy="19" r="2.5" fill="currentColor" opacity="0.7" />
          </>
        )}
        {thumbIcon === 'wave' && (
          <>
            <path d="M6 20 Q16 6 26 20" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" opacity="0.95" />
            <circle cx="16" cy="20" r="3" fill="white" opacity="0.9" />
          </>
        )}
        {thumbIcon === 'dots' && (
          <>
            <circle cx="16" cy="16" r="8" fill="none" stroke="white" stroke-width="2" stroke-dasharray="3 3" opacity="0.8" />
            <circle cx="16" cy="16" r="2" fill="white" opacity="0.8" />
          </>
        )}
        {thumbIcon === 'ring' && (
          <>
            <circle cx="16" cy="16" r="9" fill="none" stroke="white" stroke-width="2.5" opacity="0.95" />
            <circle cx="16" cy="16" r="2" fill="white" opacity="0.9" />
          </>
        )}
      </svg>
    )}
  </div>

  <div class="work-year">{year}</div>

  <div>
    <div class="work-title">{title}</div>
    <div class="work-desc">{description}</div>
  </div>

  <div class="work-tags">
    {tags.map((tag) => <span class="work-tag">{tag}</span>)}
  </div>

  <div class="work-arrow">↗</div>
</a>
