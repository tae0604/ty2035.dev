---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog'))
  .filter((p) => p.data.draft !== true)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(posts.flatMap((post) => post.data.tags || []))].sort();

const fmtDate = (d: Date) =>
  new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).format(d);

const stripMarkers = (s: string) => s.replace(/\*([^*]+)\*/g, '$1');
---

<BaseLayout
  title="Blog — ty2035.dev"
  description="Notes and posts by Tae Young Ryu."
>
  <main class="index-container">
    <header class="index-head">
      <div class="section-label">Blog</div>
      <h1 class="index-title">All <span class="italic-serif">posts</span>.</h1>
      <p class="index-lede">
        Every post I've written, newest first. Some are notes, some are longer thoughts.
      </p>
    </header>

    {allTags.length > 0 && (
      <div class="blog-filters">
        <button class="filter-tag active" data-tag="all">All</button>
        {allTags.map((tag) => (
          <button class="filter-tag" data-tag={tag}>#{tag}</button>
        ))}
      </div>
    )}

    {posts.length === 0 ? (
      <div class="blog-empty">Nothing here yet. Working on it.</div>
    ) : (
      <ul class="blog-list">
        {posts.map((post) => (
          <li class="blog-item" data-tags={JSON.stringify(post.data.tags || [])}>
            <a href={`/blog/${post.slug}/`} class="blog-link">
              <span class="blog-date">{fmtDate(post.data.date)}</span>
              <span class="blog-title">{stripMarkers(post.data.title)}</span>
              <span class="blog-arrow">→</span>
            </a>
          </li>
        ))}
      </ul>
    )}

    <nav class="index-back">
      <a href="/" class="blog-all">
        <span class="blog-all-arrow">←</span>
        <span>Back home</span>
      </a>
    </nav>
  </main>

  <script>
    const buttons = document.querySelectorAll('.filter-tag');
    const items = document.querySelectorAll('.blog-item');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');

        const selectedTag = btn.getAttribute('data-tag');

        items.forEach((item) => {
          const tagsAttr = item.getAttribute('data-tags');
          const tags = tagsAttr ? JSON.parse(tagsAttr) : [];

          if (selectedTag === 'all' || tags.includes(selectedTag)) {
            (item as HTMLElement).style.display = 'block';
          } else {
            (item as HTMLElement).style.display = 'none';
          }
        });
      });
    });
  </script>
</BaseLayout>